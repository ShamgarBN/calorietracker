# Copy to .env.local and fill in from your Supabase project (Settings → API).
# These two are SAFE to expose in a static client — Row Level Security protects rows.
# You can reuse an EXISTING project (e.g. Paperplate) — this app lives in its own
# `tracker` schema so it won't collide. See the README "Sharing a project" section.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Postgres schema this app uses. Default `tracker`. Must match supabase/schema.sql
# and the dashboard's Settings → API → "Exposed schemas" list.
VITE_DB_SCHEMA=tracker

# Optional: override the base path for GitHub Pages project sites (set by CI normally).
# BASE_PATH=/calorie-tracker/
